local MainTab = Window:CreateTab("Main", 4483362458)
local Section = MainTab:CreateSection("Farm)

local AutoFarmEnabled = false
local AutoFarmLoop = nil
local LastVisualPosition = nil

local function findVisualTicket()
    local success, result = pcall(function()
        local visualTicket = Workspace.Game.Effects.Tickets.Visual
        if visualTicket and visualTicket:IsA("Model") then
            return visualTicket
        end
        return nil
    end)
    
    if success and result then
        return result
    end
    
    return nil
end

local function getVisualPosition(visualModel)
    if not visualModel or not visualModel:IsA("Model") then return nil end
    
    local primaryPart = visualModel.PrimaryPart or visualModel:FindFirstChildWhichIsA("BasePart")
    
    if not primaryPart then
        for _, descendant in pairs(visualModel:GetDescendants()) do
            if descendant:IsA("BasePart") then
                primaryPart = descendant
                break
            end
        end
    end
    
    if primaryPart then
        return primaryPart.Position
    end
    
    return nil
end

local function spamTeleportRoutine()
    while AutoFarmEnabled do
        if not character or not humanoidRootPart then
            task.wait(0.01)
            continue
        end
        
        local visualTicket = findVisualTicket()
        
        if visualTicket then
            local visualPos = getVisualPosition(visualTicket)
            if visualPos then
                LastVisualPosition = visualPos
                local teleportPos = visualPos + Vector3.new(0, -6, 0)
                
                pcall(function()
                    humanoidRootPart.CFrame = CFrame.new(teleportPos)
                end)
            end
            
        else
            if LastVisualPosition then
                -- Spam teleport to last known Visual position
                pcall(function()
                    local spamPos = LastVisualPosition + Vector3.new(0, -6, 0)
                    humanoidRootPart.CFrame = CFrame.new(spamPos)
                end)
            else
                pcall(function()
                    local currentPos = humanoidRootPart.Position
                    humanoidRootPart.CFrame = CFrame.new(currentPos)
                end)
            end
        end
        
        task.wait(0.01)
    end
end

local function startSpamFarm()
    Rayfield:Notify({
        Title = "AutoFarm Mulai",
        Content = "AutoFarm",
        Duration = 2,
        Image = 4483362458,
    })
    
    AutoFarmLoop = task.spawn(spamTeleportRoutine)
end

local function stopSpamFarm()
    if AutoFarmLoop then
        task.cancel(AutoFarmLoop)
        AutoFarmLoop = nil
    end
    LastVisualPosition = nil
    
    Rayfield:Notify({
        Title = "AutoFarm Selesai",
        Content = "AutoFarm",
        Duration = 2,
        Image = 4483362458,
    })
end

local Toggle = MainTab:CreateToggle({
