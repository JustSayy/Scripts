local StatusTab = Window:CreateTab("Status", 4483362458)
local StatusSection = StatusTab:CreateSection("Farm Status")

local VisualStatusLabel = StatusTab:CreateLabel("Tickets Status: Checking...")
local PositionLabel = StatusTab:CreateLabel("Last Position: None")
local TeleportCount = 0
local TeleportLabel = StatusTab:CreateLabel("Teleports: 0")

task.spawn(function()
    while true do
        if AutoFarmEnabled then
            local visualTicket = findVisualTicket()
            if visualTicket then
                VisualStatusLabel:Set("Tickets Status: FOUND")
                local visualPos = getVisualPosition(visualTicket)
                if visualPos then
                    PositionLabel:Set("Last Position: " .. tostring(visualPos))
                end
            else
                VisualStatusLabel:Set("Tickets  Status: NOT FOUND")
                if LastVisualPosition then
                    PositionLabel:Set("Last Position: " .. tostring(LastVisualPosition))
                else
                    PositionLabel:Set("Last Position: None")
                end
            end
            TeleportLabel:Set("Teleports: " .. tostring(TeleportCount))
        else
            VisualStatusLabel:Set("Tickets Status: OFF")
            PositionLabel:Set("Last Position: None")
        end
        task.wait(0.1)
    end
end)

task.spawn(function()
    while true do
        if AutoFarmEnabled then
            TeleportCount = TeleportCount + 1
        else
            TeleportCount = 0
        end
        task.wait(0.01)
    end
end)

